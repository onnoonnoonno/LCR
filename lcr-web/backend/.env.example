# Server
PORT=3001
NODE_ENV=development

# CORS - comma-separated list of allowed origins
# Example: http://localhost:5173,https://lcr.example.com
CORS_ORIGINS=http://localhost:5173

# File upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Admin action password
# Protects: History delete, Account Mapping add/edit/delete
# Set to a strong password. Leave empty ("") to disable protection in development.
ADMIN_ACTION_PASSWORD=

# Database (PostgreSQL / Supabase)
# Local dev:   postgresql://postgres:password@localhost:5432/lcr
# Supabase:    postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Authentication
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=8h

# IP Allowlist (comma-separated CIDR blocks)
# IP_ALLOWLIST=10.0.0.0/8,192.168.0.0/16
